---
import Layout from "../layouts/Layout.astro";
import Icon from "../components/Icon.astro";

const whatIDo = [
  {
    icon: "target",
    title: "Marketing",
    body: "Planning, positioning and practical strategy that helps organizations communicate more effectively.",
  },
  {
    icon: "pencil",
    title: "Content",
    body: "Websites, articles, newsletters and thought leadership designed for real audiences.",
  },
  {
    icon: "chat",
    title: "Communications",
    body: "Public relations, messaging and audience engagement across digital, print and in-person channels.",
  },
  {
    icon: "clipboard",
    title: "Project Management",
    body: "Keeping people, priorities and projects aligned from idea through execution.",
  },
] as const;

const links = [
  { icon: "folder", label: "Portfolio", href: "#" },
  { icon: "linkedin", label: "LinkedIn", href: "https://www.linkedin.com/in/jacohen614" },
  { icon: "calendar", label: "Let's Meet", href: "https://calendar.app.google/KDfkHdEhf4fBwj7o9" },
] as const;

const outsideOfWork = [
  { icon: "pulse", label: "Cardio", href: "#" },
  { icon: "music-note", label: "Music", href: "#" },
] as const;
---

<Layout>
  <main>
    <!-- Hero -->
    <section class="relative mx-3 mt-3 overflow-hidden rounded-2xl sm:mx-6 sm:mt-6">
      <img
        src="/images/hero-bg.jpg"
        alt="Sunset over the mountains near Tucson, Arizona"
        class="h-[70vh] min-h-[420px] w-full object-cover sm:h-[75vh]"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/25 via-black/0 to-black/10"></div>
      <div class="absolute inset-x-0 top-0 p-6 sm:p-12">
        <h1 class="font-display max-w-xl text-5xl leading-[1.05] font-semibold text-ink sm:text-6xl">
          Reclaimed Imagination
        </h1>
        <div class="mt-5 h-[3px] w-14 bg-rust"></div>
        <p class="mt-5 max-w-xs font-body text-lg leading-snug text-ink/90 sm:text-xl">
          Marketing consulting from sunny Tucson, Arizona.
        </p>
      </div>
    </section>

    <div class="mx-auto max-w-5xl px-6 sm:px-8">
      <!-- What I Do -->
      <section class="pt-16 sm:pt-20">
        <p class="eyebrow">What I Do</p>
        <div class="mt-1 mb-10 h-px w-10 bg-rust/40"></div>
        <div class="grid grid-cols-1 gap-x-8 gap-y-10 sm:grid-cols-2 lg:grid-cols-4">
          {
            whatIDo.map((item) => (
              <div>
                <Icon name={item.icon} class="h-11 w-11 text-rust" />
                <h3 class="font-display mt-4 text-xl font-semibold text-ink">{item.title}</h3>
                <p class="mt-2 text-[0.95rem] leading-relaxed text-ink/70">{item.body}</p>
              </div>
            ))
          }
        </div>
      </section>

      <!-- Links -->
      <section class="border-t border-ink/10 pt-14 pb-4 sm:pt-16">
        <p class="eyebrow">Links</p>
        <div class="mt-1 mb-10 h-px w-10 bg-rust/40"></div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
          {
            links.map((link) => (
              <a
                href={link.href}
                target={link.href.startsWith("http") ? "_blank" : undefined}
                rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
                class="group flex flex-col items-center gap-4 rounded-xl border border-ink/15 px-6 py-10 text-center transition-colors hover:border-rust/50 hover:bg-rust/5"
              >
                <Icon
                  name={link.icon}
                  class={
                    link.icon === "linkedin"
                      ? "h-11 w-11 text-rust"
                      : "h-11 w-11 text-rust"
                  }
                />
                <span class="font-display text-lg font-semibold text-ink">{link.label}</span>
                <Icon name="arrow-right" class="h-4 w-4 text-rust transition-transform group-hover:translate-x-1" />
              </a>
            ))
          }
        </div>
      </section>

      <!-- About -->
      <section class="border-t border-ink/10 pt-14 pb-4 sm:pt-16">
        <p class="eyebrow">About</p>
        <div class="mt-1 mb-10 h-px w-10 bg-rust/40"></div>
        <div class="grid grid-cols-1 gap-10 lg:grid-cols-2 lg:items-start lg:gap-14">
          <div>
            <h2 class="font-display text-3xl font-semibold text-ink sm:text-4xl">Strategy. Story. Purpose.</h2>
            <div class="mt-5 space-y-4 text-[0.98rem] leading-relaxed text-ink/75">
              <p>
                I live at the intersection of strategy, story, and purpose, helping organizations communicate with
                clarity and reach the audiences they're trying to serve. My focus is on creating authentic,
                emotionally intelligent marketing that builds trust, creates meaningful relationships, and helps
                organizations achieve their goals.
              </p>
              <p>
                Across more than 15 years in marketing, I've adapted strategy and messaging to meet the needs of
                organizations across a variety of industries.
              </p>
              <p>
                Having experience across the full marketing lifecycle, from strategy and ideation through execution,
                reporting, and refinement, I help organizations turn thoughtful ideas into meaningful marketing
                results.
              </p>
              <p>Outside of work I am often spending time with my family, running, and listening to music.</p>
            </div>
          </div>
          <img
            src="/images/headshot.jpg"
            alt="Josh Cohen, founder of Reclaimed Imagination"
            class="aspect-[4/5] w-full rounded-2xl object-cover"
          />
        </div>
      </section>

      <!-- Outside of Work -->
      <section class="border-t border-ink/10 pt-14 pb-16 sm:pt-16 sm:pb-20">
        <p class="eyebrow">Outside of Work</p>
        <div class="mt-1 mb-10 h-px w-10 bg-rust/40"></div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          {
            outsideOfWork.map((item) => (
              <a
                href={item.href}
                class="group flex items-center justify-between rounded-xl border border-ink/15 px-6 py-6 transition-colors hover:border-rust/50 hover:bg-rust/5"
              >
                <span class="flex items-center gap-4">
                  <Icon name={item.icon} class="h-8 w-8 text-rust" />
                  <span class="font-display text-lg font-semibold text-ink">{item.label}</span>
                </span>
                <Icon name="arrow-right" class="h-4 w-4 text-rust transition-transform group-hover:translate-x-1" />
              </a>
            ))
          }
        </div>
      </section>
    </div>

    <!-- Footer -->
    <footer class="relative mx-3 mb-3 overflow-hidden rounded-2xl bg-ink sm:mx-6 sm:mb-6">
      <div class="relative z-10 flex flex-col gap-8 px-6 py-12 sm:flex-row sm:items-center sm:justify-between sm:px-12">
        <div>
          <h2 class="font-display text-3xl font-semibold text-cream">Let's connect.</h2>
          <div class="mt-3 h-[3px] w-10 bg-rust"></div>
          <p class="mt-4 max-w-xs text-[0.95rem] text-cream/70">
            I'm always up for good conversation and even better ideas.
          </p>
        </div>
        <div class="flex flex-col gap-3 text-cream/90">
          <a href="mailto:josh@reclaimedimagination.com" class="flex items-center gap-3 hover:text-rust-light">
            <Icon name="envelope" class="h-5 w-5 text-rust" />
            josh@reclaimedimagination.com
          </a>
          <span class="flex items-center gap-3">
            <Icon name="map-pin" class="h-5 w-5 text-rust" />
            Tucson, Arizona
          </span>
        </div>
      </div>
      <svg
        class="pointer-events-none absolute right-0 bottom-0 h-28 w-full text-rust/70 sm:h-32 sm:w-2/3"
        viewBox="0 0 500 140"
        preserveAspectRatio="xMaxYMax meet"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <circle cx="430" cy="35" r="10" fill="currentColor" />
        <path
          d="M0 140 100 60 150 95 220 30 280 90 330 55 400 110 440 75 500 140"
          stroke="currentColor"
          stroke-width="2"
          stroke-linejoin="round"
          stroke-linecap="round"
        />
      </svg>
    </footer>
  </main>
</Layout>
