---
import Layout from "../layouts/Layout.astro";
import Icon from "../components/Icon.astro";
import footerMountain from "../assets/footer-mountain.svg?raw";

const calendarUrl = "https://calendar.app.google/KDfkHdEhf4fBwj7o9";

const whatIDo = [
  {
    icon: "clipboard",
    title: "Strategy",
    body: "Marketing decisions begin by understanding where you want to go. Let's define your path, identify your audience, and establish your priorities, so you can show up intentionally.",
  },
  {
    icon: "pencil",
    title: "Story",
    body: "People rarely make decisions based on information alone. They act when your story reflects their values, experiences, and aspirations.",
  },
  {
    icon: "target",
    title: "Purpose",
    body: "Activity alone won't accomplish your goals. Marketing initiatives should serve your organization's purpose and help accomplish your goals.",
  },
] as const;

const links = [
  {
    icon: "folder",
    label: "Portfolio",
    href: "https://drive.google.com/file/d/1e0NUa65_6MMd0ON7nvK8lGV2ULYUMX0S/view?usp=sharing",
  },
  { icon: "linkedin", label: "LinkedIn", href: "https://www.linkedin.com/in/jacohen614" },
  { icon: "calendar", label: "Let's Meet", href: calendarUrl },
] as const;

const testimonials = [
  {
    quote:
      "I've really enjoyed working with Josh on our website and digital marketing efforts. He's been incredibly easy to work with, responsive, and proactive throughout the entire engagement. Coming into this, I didn't have a clear strategy or much experience with digital marketing or building an online presence. Josh helped simplify what initially felt like an overwhelming aspect of the business and provided a practical roadmap that has been both effective and easy to maintain alongside the demands of serving wealth management clients.",
    name: "Chase G.",
  },
  {
    quote:
      "Working with Josh is a pleasure and he has become an essential member of our development and communications team. Since coming on board six months ago, we have seen a substantial improvement in Google Ad Grant funding utilization. What I appreciate about Josh is his strong work ethic, his commitment to excellence, brand awareness, and his proactive desire to learn and improve results.",
    name: "Andrea D.",
  },
  {
    quote:
      "Josh created a professional and polished product for our organization. He's especially talented at conveying information effectively in a fun and accessible style. We absolutely hope to work with him again.",
    name: "Samara K.",
  },
  {
    quote:
      "My experience working with Josh has been great! He's incredibly knowledgeable and has done an excellent job guiding us on crafting the right messaging for our intended audience. He consistently keeps us on track with marketing timelines and isn't afraid to share his opinion on what he thinks will (or won't) resonate with our audience, which has been invaluable. One of the things I appreciate most is his genuine curiosity to understand what we do and who we serve. Not only has that made working together enjoyable, but I believe it also enables Josh to provide more thoughtful, effective guidance that is tailored to our unique needs.",
    name: "Sergio O.",
  },
] as const;
---

<Layout>
  <!-- Nav -->
  <div class="fixed top-6 right-8 z-50 sm:top-9 sm:right-11">
    <details class="group" data-nav>
      <summary
        class="flex cursor-pointer list-none items-center justify-center p-1 text-ink/70 transition-colors hover:text-rust [&::-webkit-details-marker]:hidden"
      >
        <Icon name="menu" class="h-6 w-6 drop-shadow-[0_1px_3px_rgba(0,0,0,0.3)]" />
      </summary>
      <nav class="absolute right-0 mt-2 w-52 rounded-xl border border-ink/10 bg-cream p-2 shadow-lg">
        <a
          href="#what-i-do"
          class="block rounded-lg px-3 py-2 font-body text-sm font-semibold text-ink transition-colors hover:bg-rust/10 hover:text-rust"
        >
          What I Do
        </a>
        <a
          href="#links"
          class="block rounded-lg px-3 py-2 font-body text-sm font-semibold text-ink transition-colors hover:bg-rust/10 hover:text-rust"
        >
          Links
        </a>
        <a
          href="#about"
          class="block rounded-lg px-3 py-2 font-body text-sm font-semibold text-ink transition-colors hover:bg-rust/10 hover:text-rust"
        >
          About Josh
        </a>
        <a
          href="#testimonials"
          class="block rounded-lg px-3 py-2 font-body text-sm font-semibold text-ink transition-colors hover:bg-rust/10 hover:text-rust"
        >
          Testimonials
        </a>
        <a
          href="#contact"
          class="block rounded-lg px-3 py-2 font-body text-sm font-semibold text-ink transition-colors hover:bg-rust/10 hover:text-rust"
        >
          Contact
        </a>
      </nav>
    </details>
  </div>

  <main>
    <!-- Hero -->
    <section class="relative mx-3 mt-3 min-h-[max(340px,38vw)] overflow-hidden rounded-2xl sm:mx-6 sm:mt-6">
      <img
        src="/images/hero-bg.jpg"
        alt="Sunset sky over the mountains near Tucson, Arizona"
        class="absolute inset-0 h-full w-full object-cover object-top"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/10 via-black/0 to-black/5"></div>
      <div class="relative p-6 sm:p-12">
        <h1
          class="hero-in font-display max-w-2xl text-5xl leading-[1.03] font-semibold text-ink sm:text-6xl lg:text-7xl"
          style="animation-delay: 0ms"
        >
          Reclaimed Imagination
        </h1>
        <div class="hero-in mt-5 h-[3px] w-14 bg-rust" style="animation-delay: 250ms"></div>
        <p
          class="hero-in mt-5 font-body text-base leading-snug text-ink/90 sm:text-lg sm:whitespace-nowrap lg:text-xl"
          style="animation-delay: 500ms"
        >
          Marketing consulting from sunny Tucson, Arizona.
        </p>
      </div>
    </section>

    <div class="mx-auto max-w-5xl px-6 sm:px-8">
      <!-- What I Do -->
      <section id="what-i-do" class="pt-16 sm:pt-20">
        <p class="eyebrow" data-reveal>What I Do</p>
        <div class="mt-2 mb-10 h-px w-10 bg-rust/40" data-reveal-line></div>
        <div class="grid grid-cols-1 gap-x-10 gap-y-14 sm:grid-cols-3">
          {
            whatIDo.map((item, i) => (
              <div data-reveal style={`transition-delay: ${i * 160}ms`}>
                <Icon name={item.icon} class="h-11 w-11 text-rust" />
                <h3 class="font-display mt-4 text-xl font-semibold text-ink">{item.title}</h3>
                <p class="mt-2 text-[0.95rem] leading-relaxed text-ink/70">{item.body}</p>
              </div>
            ))
          }
        </div>
      </section>

      <!-- Links -->
      <section id="links" class="pt-14 pb-4 sm:pt-16">
        <p class="eyebrow" data-reveal>Links</p>
        <div class="mt-2 mb-10 h-px w-10 bg-rust/40" data-reveal-line></div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
          {
            links.map((link, i) => (
              <a
                href={link.href}
                target={link.href.startsWith("http") ? "_blank" : undefined}
                rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
                class="group flex flex-col items-center gap-4 rounded-xl border border-ink/15 px-6 py-10 text-center transition-colors hover:border-rust/50 hover:bg-rust/5"
                data-reveal
                style={`transition-delay: ${i * 160}ms`}
              >
                <span class="flex h-11 w-11 items-center justify-center">
                  <Icon name={link.icon} class={link.icon === "linkedin" ? "h-8 w-8 text-rust" : "h-11 w-11 text-rust"} />
                </span>
                <span class="font-display text-lg font-semibold text-ink">{link.label}</span>
                <Icon name="arrow-right" class="h-4 w-4 text-rust transition-transform group-hover:translate-x-1" />
              </a>
            ))
          }
        </div>
      </section>

      <!-- About -->
      <section id="about" class="border-t border-ink/10 pt-14 pb-4 sm:pt-16">
        <p class="eyebrow" data-reveal>About</p>
        <div class="mt-2 mb-10 h-px w-10 bg-rust/40" data-reveal-line></div>
        <div class="grid grid-cols-1 gap-10 lg:grid-cols-2 lg:items-start lg:gap-14">
          <div data-reveal>
            <h2 class="font-display text-3xl font-semibold text-ink sm:text-4xl">Strategy. Story. Purpose.</h2>
            <div class="mt-5 space-y-4 text-[0.98rem] leading-relaxed text-ink/75">
              <p>
                I live at the intersection of strategy, story, and purpose, helping organizations communicate with
                clarity and reach the audiences they're trying to serve. My focus is on creating authentic,
                emotionally intelligent marketing that builds trust, creates meaningful relationships, and helps
                organizations achieve their goals.
              </p>
              <p>
                Across more than 15 years in marketing, I've adapted strategy and messaging to meet the needs of
                organizations across a variety of industries.
              </p>
              <p>
                Having experience across the full marketing lifecycle, from strategy and ideation through execution,
                reporting, and refinement, I help organizations turn thoughtful ideas into meaningful marketing
                results.
              </p>
              <p>Outside of work I am often spending time with my family, running, and listening to music.</p>
            </div>
          </div>
          <div data-reveal style="transition-delay: 200ms">
            <img
              src="/images/headshot.jpg"
              alt="Josh Cohen, founder of Reclaimed Imagination"
              class="aspect-[4/5] w-full rounded-2xl object-cover"
            />
            <div class="mt-4 text-center">
              <p class="font-display text-lg font-semibold text-ink">Josh Cohen</p>
              <p class="text-sm text-ink/60">Marketing Consultant</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Testimonials -->
      <section id="testimonials" class="border-t border-ink/10 pt-14 pb-16 sm:pt-16 sm:pb-20">
        <p class="eyebrow" data-reveal>Testimonials</p>
        <div class="mt-2 mb-10 h-px w-10 bg-rust/40" data-reveal-line></div>
        <div class="grid grid-cols-1 items-start gap-6 sm:grid-cols-2">
          {
            testimonials.map((t, i) => (
              <blockquote
                class="rounded-xl border border-ink/15 p-6 sm:p-8"
                data-reveal
                style={`transition-delay: ${i * 120}ms`}
              >
                <Icon name="quote" class="h-7 w-7 text-rust/60" />
                <p class="mt-3 text-[0.95rem] leading-relaxed text-ink/75">{t.quote}</p>
                <footer class="mt-4 font-display text-base font-semibold text-rust">{t.name}</footer>
              </blockquote>
            ))
          }
        </div>
      </section>
    </div>

    <!-- Footer -->
    <footer id="contact" class="relative mx-3 mb-3 overflow-hidden rounded-2xl bg-ink sm:mx-6 sm:mb-6">
      <div class="relative z-10 flex flex-col gap-8 px-6 py-12 sm:flex-row sm:items-center sm:gap-16 sm:px-12">
        <div>
          <h2 class="font-display text-3xl font-semibold text-cream">Let's connect.</h2>
          <div class="mt-3 h-[3px] w-10 bg-rust"></div>
          <p class="mt-4 max-w-xs text-[0.95rem] text-cream/70">
            I'm always up for good conversation and even better ideas.
          </p>
        </div>
        <div class="flex flex-col gap-3 text-cream/90">
          <a href="mailto:josh@reclaimedimagination.com" class="flex items-center gap-3 hover:text-rust-light">
            <Icon name="envelope" class="h-5 w-5 text-rust" />
            josh@reclaimedimagination.com
          </a>
          <a href={calendarUrl} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 hover:text-rust-light">
            <Icon name="calendar" class="h-5 w-5 text-rust" />
            Let's Meet
          </a>
          <span class="flex items-center gap-3">
            <Icon name="map-pin" class="h-5 w-5 text-rust" />
            Tucson, Arizona
          </span>
        </div>
      </div>
      <div
        class="pointer-events-none absolute right-0 bottom-0 h-28 w-full text-rust/70 sm:h-32 sm:w-2/3"
        set:html={footerMountain}
      />
    </footer>
  </main>

  <script>
    document.querySelectorAll<HTMLAnchorElement>("[data-nav] nav a").forEach((a) => {
      a.addEventListener("click", () => a.closest("details")?.removeAttribute("open"));
    });

    document.addEventListener("click", (e) => {
      const nav = document.querySelector("[data-nav]");
      if (nav?.hasAttribute("open") && !nav.contains(e.target as Node)) {
        nav.removeAttribute("open");
      }
    });
  </script>
</Layout>
