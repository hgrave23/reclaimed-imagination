---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page Not Found | Reclaimed Imagination">
  <main class="flex min-h-screen flex-col items-center justify-center bg-cream px-6 text-center">
    <p class="eyebrow">404</p>
    <h1 class="font-display mt-3 text-4xl font-semibold text-ink sm:text-5xl">Page not found</h1>
    <p class="mt-4 max-w-sm text-ink/70">The page you're looking for doesn't exist.</p>
    <a
      href="/"
      class="mt-8 inline-flex items-center gap-2 rounded-full border border-ink/15 px-6 py-3 font-semibold text-ink transition-colors hover:border-rust/50 hover:bg-rust/5"
    >
      Back to home
    </a>
  </main>
</Layout>
