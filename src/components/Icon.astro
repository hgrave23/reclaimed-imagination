---
interface Props {
  name:
    | "target"
    | "pencil"
    | "chat"
    | "clipboard"
    | "folder"
    | "calendar"
    | "linkedin"
    | "envelope"
    | "map-pin"
    | "arrow-right"
    | "strava"
    | "spotify"
    | "menu";
  class?: string;
}

const { name, class: className = "" } = Astro.props;
---

{
  name === "target" && (
    <svg viewBox="0 0 48 48" fill="none" class={className} xmlns="http://www.w3.org/2000/svg">
      <circle cx="24" cy="24" r="16" stroke="currentColor" stroke-width="2" />
      <circle cx="24" cy="24" r="9" stroke="currentColor" stroke-width="2" />
      <circle cx="24" cy="24" r="2.25" fill="currentColor" />
    </svg>
  )
}
{
  name === "pencil" && (
    <svg viewBox="0 0 48 48" fill="none" class={className} xmlns="http://www.w3.org/2000/svg">
      <path
        d="M13 35.5 33.7 14.8a3 3 0 0 1 4.24 0l1.26 1.26a3 3 0 0 1 0 4.24L18.5 39 11 41z"
        stroke="currentColor"
        stroke-width="2"
        stroke-linejoin="round"
      />
      <path d="M29.5 18 34 22.5" stroke="currentColor" stroke-width="2" />
    </svg>
  )
}
{
  name === "chat" && (
    <svg viewBox="0 0 48 48" fill="none" class={className} xmlns="http://www.w3.org/2000/svg">
      <path
        d="M9 15a4 4 0 0 1 4-4h22a4 4 0 0 1 4 4v14a4 4 0 0 1-4 4H21l-8 7v-7h-.5A3.5 3.5 0 0 1 9 31.5z"
        stroke="currentColor"
        stroke-width="2"
        stroke-linejoin="round"
      />
    </svg>
  )
}
{
  name === "clipboard" && (
    <svg viewBox="0 0 48 48" fill="none" class={className} xmlns="http://www.w3.org/2000/svg">
      <rect x="12" y="10" width="24" height="30" rx="2.5" stroke="currentColor" stroke-width="2" />
      <path d="M19 10a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v2H19z" stroke="currentColor" stroke-width="2" />
      <path d="M18 21h12M18 27h12M18 33h8" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
    </svg>
  )
}
{
  name === "folder" && (
    <svg viewBox="0 0 48 48" fill="none" class={className} xmlns="http://www.w3.org/2000/svg">
      <path
        d="M8 15a2 2 0 0 1 2-2h9l3 4h16a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2H10a2 2 0 0 1-2-2z"
        stroke="currentColor"
        stroke-width="2"
        stroke-linejoin="round"
      />
    </svg>
  )
}
{
  name === "calendar" && (
    <svg viewBox="0 0 48 48" fill="none" class={className} xmlns="http://www.w3.org/2000/svg">
      <rect x="9" y="11" width="30" height="27" rx="2.5" stroke="currentColor" stroke-width="2" />
      <path d="M9 19h30" stroke="currentColor" stroke-width="2" />
      <path d="M16 7v8M32 7v8" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      <rect x="15" y="24" width="6" height="6" rx="1" fill="currentColor" />
    </svg>
  )
}
{
  name === "linkedin" && (
    <svg viewBox="0 0 24 24" class={className} xmlns="http://www.w3.org/2000/svg">
      <rect width="24" height="24" rx="5" fill="currentColor" />
      <path
        fill="#f8f3ee"
        d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452z"
      />
    </svg>
  )
}
{
  name === "envelope" && (
    <svg viewBox="0 0 48 48" fill="none" class={className} xmlns="http://www.w3.org/2000/svg">
      <rect x="7" y="12" width="34" height="24" rx="3" stroke="currentColor" stroke-width="2" />
      <path d="M8 14l16 13 16-13" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
